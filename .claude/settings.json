{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(sleep *)",
      "Bash(find *)",
      "Bash(du *)",
      "Bash(node *)",
      "Bash(for *)",
      "Bash(powershell *)",
      "Bash(where *)",
      "Bash(schtasks *)",
      "Read(**)",
      "Skill(*)",
      "Skill(*:*)",
      "Bash(find /d/dev/crucible/web -type f \\\\\\(-name *.tsx -o -name *.ts -o -name *.jsx -o -name *.js \\\\\\))",
      "Bash(xargs -I {} basename {} .py)"
    ],
    "additionalDirectories": [
      "d:\\dev\\crucible"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd d:/dev/crucible && git add CONTEXT.md && git diff --cached --quiet || (git commit -m \"Update CONTEXT.md session notes\" && git push)",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
